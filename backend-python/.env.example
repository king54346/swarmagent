# Database
# SQLite database file path (default: agent_wechat.db in backend-python directory)
DATABASE_URL=agent_wechat.db

# Redis connection URL
REDIS_URL=redis://localhost:6379

# LLM Provider: glm | openrouter | qwen | anthropic | openai
LLM_PROVIDER=glm

# GLM (智谱 AI)
GLM_API_KEY=replace_me
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4.7

# Qwen (通义千问 / DashScope)
QWEN_API_KEY=replace_me
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-max

# OpenRouter (OpenAI-compatible)
OPENROUTER_API_KEY=replace_me
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Anthropic
ANTHROPIC_API_KEY=replace_me
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# OpenAI
OPENAI_API_KEY=replace_me
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# MCP Configuration
MCP_CONFIG_PATH=mcp.json
MCP_TIMEOUT_MS=30000
MCP_LOAD_TIMEOUT_MS=2000

# Agent workspace directory for bash tool
AGENT_WORKDIR=
